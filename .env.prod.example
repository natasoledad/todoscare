# ─────────── TODOSCARE — variables de producción ───────────
# Copia este archivo a .env y edítalo. NO subas .env al repo.

# Postgres (el servicio 'db' del compose usa estas credenciales)
POSTGRES_USER=todoscare
POSTGRES_PASSWORD=cambia-esta-clave-fuerte
POSTGRES_DB=todoscare

# URL async que usa el backend (host = nombre del servicio 'db')
DATABASE_URL=postgresql+asyncpg://todoscare:cambia-esta-clave-fuerte@db:5432/todoscare

# JWT — GENERA UN SECRETO FUERTE, p. ej.:  openssl rand -hex 32
JWT_SECRET=cambia-esto-por-un-secreto-de-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Orígenes CORS permitidos (la SPA va same-origin vía nginx, pero fíjalo al
# dominio público por si se consume la API desde otro origen)
CORS_ORIGINS=https://app.todoscare.com

# Nº de workers de gunicorn (≈ 2 × núcleos + 1)
WEB_CONCURRENCY=4

# Puerto público del servicio web (nginx). Detrás de un balanceador con TLS
# normalmente lo dejas en 80 y terminas HTTPS fuera.
WEB_PORT=80

# Poner en 'true' SOLO en el primer arranque para cargar datos demo; luego
# vuelve a 'false'. En producción real déjalo en false.
SEED_ON_START=false
