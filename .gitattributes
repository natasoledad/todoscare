# Normaliza saltos de línea: scripts y config que corren en Linux/containers
# SIEMPRE con LF, aunque se clonen en Windows (evita el error `bash\r`).
* text=auto eol=lf

*.sh            text eol=lf
entrypoint.sh   text eol=lf
Dockerfile      text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.conf          text eol=lf

# Binarios: sin conversión
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 binary
